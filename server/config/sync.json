{
  "local": {
    "host": "127.0.0.1",
    "port": 3306,
    "user": "root",
    "password": "${LOCAL_DB_PASSWORD}",
    "database": "train_departure_diary"
  },
  "backup": {
    "dir": "./db_backup",
    "retentionDays": 30
  },
  "sync": {
    "cronFull": "0 2 * * 0",
    "cronIncremental": "0 2 * * 1-6"
  },
  "tables": ["users", "merchants", "workers", "departures", "transactions", "settings", "daily_quotes", "invitation_codes"]
}
